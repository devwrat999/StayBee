<% layout("/layouts/boilerplate") %>

<!-- jiya: Admin Rejected Listings page -->

<div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mt-3">
  <div>
    <h3 class="mb-0">Rejected Listings</h3>
    <p class="text-muted mb-0" style="font-size: 0.9rem;">
      View listings that were rejected and may need user resubmission.
    </p>
  </div>
  <div>
    <a href="/admin/pending-listings" class="btn btn-outline-secondary">
      <i class="bi bi-clock"></i> View Pending Approvals
    </a>
  </div>
</div>

<% if (allListing.length === 0) { %>
  <div class="alert alert-danger mt-4">
    <h5 class="alert-heading">No rejected listings</h5>
    <p class="mb-0">No listings have been rejected yet.</p>
  </div>
<% } else { %>
  <div class="row mt-4">
    <% allListing.forEach(listing => { %>
      <div class="col-md-6 col-lg-4 mb-4">
        <div class="card h-100 border-danger">
          <% if (listing.image && listing.image.length > 0) { %>
            <div class="carousel-inner">
              <% const hasImages = listing.images && listing.images.length > 0; %>
              <% const imgList = hasImages ? listing.images : [listing.image]; %>
              <% imgList.forEach(function (img, idx) { %>
                <div class="carousel-item <%= idx === 0 ? 'active' : '' %>">
                  <img
                    src="<%= img %>"
                    class="d-block w-100 img-lightbox-card listing-card-img"
                    alt="listing_image"
                    data-images='<%= JSON.stringify(imgList) %>'
                    data-index="<%= idx %>"
                  />
                </div>
              <% }) %>
            </div>
          <% } else { %>
            <div class="carousel-inner">
              <div class="carousel-item active">
                <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 200px;">
                  <i class="bi bi-image text-muted" style="font-size: 3rem;"></i>
                </div>
              </div>
            </div>
          <% } %>
          
          <div class="card-body d-flex flex-column">
            <h5 class="card-title"><%= listing.title %></h5>
            <p class="card-text text-muted small">
              <i class="bi bi-geo-alt"></i> <%= listing.location %>
            </p>
            <p class="card-text"><%= listing.description ? listing.description.substring(0, 100) + '...' : '' %></p>
            
            <!-- jiya: Owner information -->
            <div class="mb-2">
              <small class="text-muted">
                <i class="bi bi-person"></i> Submitted by: <%= listing.owner ? listing.owner.username : 'Unknown' %>
              </small>
            </div>
            
            <!-- jiya: Approval status badge -->
            <div class="mb-2">
              <span class="badge bg-danger">Rejected</span>
            </div>
            
            <div class="mt-auto">
              <p class="card-text fw-bold text-primary">
                ₹<%= listing.price %> <span class="text-muted fw-normal">/night</span>
              </p>
              
              <div class="btn-group w-100" role="group">
                <a href="/listings/<%= listing._id %>" class="btn btn-outline-primary btn-sm">
                  <i class="bi bi-eye"></i> View Details
                </a>
                <a href="/listings/<%= listing._id %>/edit" class="btn btn-outline-secondary btn-sm">
                  <i class="bi bi-pencil"></i> Edit
                </a>
                <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST" class="d-inline" 
                      onsubmit="return confirm('Are you sure you want to delete this listing?');">
                  <button type="submit" class="btn btn-outline-danger btn-sm">
                    <i class="bi bi-trash"></i> Delete
                  </button>
                </form>
              </div>
            </div>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
<% } %>

