<% layout("/layouts/boilerplate") %>

<!-- jiya: Admin Approved Listings History page -->

<div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mt-3">
  <div>
    <h3 class="mb-0">Approved Listings History</h3>
    <p class="text-muted mb-0" style="font-size: 0.9rem;">
      View all listings that have been approved and are now live.
    </p>
  </div>
  <div>
    <a href="/admin/pending-listings" class="btn btn-primary">
      <i class="bi bi-clock"></i> View Pending
    </a>
  </div>
</div>

<!-- jiya: Statistics -->
<div class="row mt-4">
  <div class="col-12">
    <div class="alert alert-info border-0 bg-gradient">
      <div class="row align-items-center">
        <div class="col-md-3 col-6 text-center mb-3 mb-md-0">
          <div class="d-flex align-items-center justify-content-center mb-2">
            <i class="bi bi-check-circle-fill text-primary me-2"></i>
            <span class="badge bg-primary fs-6 px-3 py-2"><%= allListing.length %></span>
          </div>
          <p class="small mb-0 fw-semibold">Total Approved</p>
        </div>
        <div class="col-md-3 col-6 text-center mb-3 mb-md-0">
          <div class="d-flex align-items-center justify-content-center mb-2">
            <i class="bi bi-star-fill text-warning me-2"></i>
            <span class="badge bg-warning text-dark fs-6 px-3 py-2">
              <%= allListing.filter(l => l.averageRating && l.averageRating >= 4).length %>
            </span>
          </div>
          <p class="small mb-0 fw-semibold">Highly Rated (4+ ⭐)</p>
        </div>
        <div class="col-md-3 col-6 text-center mb-3 mb-md-0">
          <div class="d-flex align-items-center justify-content-center mb-2">
            <i class="bi bi-house-check-fill text-info me-2"></i>
            <span class="badge bg-info fs-6 px-3 py-2">
              <%= allListing.filter(l => l.status === 'Available').length %>
            </span>
          </div>
          <p class="small mb-0 fw-semibold">Available</p>
        </div>
        <div class="col-md-3 col-6 text-center">
          <div class="d-flex align-items-center justify-content-center mb-2">
            <i class="bi bi-graph-up text-success me-2"></i>
            <span class="badge bg-success fs-6 px-3 py-2">
              <%= allListing.length > 0 ? Math.round((allListing.filter(l => l.status === 'Available').length / allListing.length) * 100) : 0 %>%
            </span>
          </div>
          <p class="small mb-0 fw-semibold">Availability Rate</p>
        </div>
      </div>
    </div>
  </div>
</div>

<% if (allListing.length === 0) { %>
  <div class="alert alert-info mt-4">
    <h5 class="alert-heading">No approved listings yet</h5>
    <p class="mb-0">No listings have been approved yet. Check the pending listings to review submissions.</p>
  </div>
<% } else { %>
  <div class="row mt-4">
    <% allListing.forEach(listing => { %>
      <div class="col-md-6 col-lg-4 mb-4">
        <div class="card h-100">
          <% if (listing.image && listing.image.length > 0) { %>
            <img src="<%= listing.image %>" class="card-img-top" alt="<%= listing.title %>" style="height: 200px; object-fit: cover;">
          <% } else { %>
            <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 200px;">
              <i class="bi bi-image text-muted" style="font-size: 3rem;"></i>
            </div>
          <% } %>
          
          <div class="card-body d-flex flex-column">
            <h5 class="card-title"><%= listing.title %></h5>
            <p class="card-text text-muted small">
              <i class="bi bi-geo-alt"></i> <%= listing.location %>
            </p>
            <p class="card-text"><%= listing.description ? listing.description.substring(0, 100) + '...' : '' %></p>
            
            <!-- jiya: Owner and approval information -->
            <div class="mb-2">
              <small class="text-muted d-block">
                <i class="bi bi-person"></i> Owner: <%= listing.owner ? listing.owner.username : 'Unknown' %>
              </small>
              <% if (listing.approvedBy) { %>
                <small class="text-muted d-block">
                  <i class="bi bi-check-circle"></i> Approved by: <%= listing.approvedBy.username %>
                </small>
              <% } %>
              <% if (listing.approvedAt) { %>
                <small class="text-muted d-block">
                  <i class="bi bi-calendar"></i> Approved: <%= new Date(listing.approvedAt).toLocaleDateString() %>
                </small>
              <% } %>
            </div>
            
            <!-- jiya: Approval status badge -->
            <div class="mb-2">
              <span class="badge bg-success">Approved</span>
            </div>
            
            <div class="mt-auto">
              <p class="card-text fw-bold text-primary">
                $<%= listing.price %> <span class="text-muted fw-normal">/night</span>
              </p>
              
              <div class="btn-group w-100" role="group">
                <a href="/listings/<%= listing._id %>" class="btn btn-outline-primary btn-sm">
                  <i class="bi bi-eye"></i> View Live
                </a>
                <a href="/listings/<%= listing._id %>/edit" class="btn btn-outline-secondary btn-sm">
                  <i class="bi bi-pencil"></i> Edit
                </a>
                <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST" class="d-inline" 
                      onsubmit="return confirm('Are you sure you want to delete this listing?');">
                  <button type="submit" class="btn btn-outline-danger btn-sm">
                    <i class="bi bi-trash"></i> Delete
                  </button>
                </form>
              </div>
            </div>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
<% } %>

