<% layout("/layouts/boilerplate") %>

<div class="row">
    <div class="col-8 offset-5">
        <h3>Listing Details :</h3>
        <br>
        <br>

  </div>

  

    <div class="card" style="width: 20rem;">
  <img src="<%= listing.image %>" class="card-img-top show_img" alt="listing_image">
  <div class="card-body">
    <p class="card-text">
        Title : <b><%= listing.title %></b>
        <br>
        Description : <%= listing.description %>
        <br>
        Price : &#8377 <%= listing.price.toLocaleString("en-IN") %>
        <br>
        Location : <%= listing.location %>
        <br>
        Country : <%= listing.country %>
        <br>
    </p>
  </div>
</div>

    <br>
    <div class="col-1">
       <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark edit_btn">Edit</a>

   </div>

   <div class="col-2">

       <form method="POST" action="/listings/<%=listing._id%>?_method=DELETE">
           <button class="btn btn-dark dlt_btn">Delete this listing </button>
       </form>
   </div>
</div>
