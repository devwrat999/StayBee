<% layout("/layouts/boilerplate") %>
<% const hasMapCoords = listing && listing.latitude != null && listing.longitude != null; %>

<div class="listing-show-page mt-4">
  <div class="row g-4">
    <div class="col-12 col-lg-7">
      <div class="d-flex align-items-center gap-2 mb-3">
        <h3 class="mb-0"><%= listing.title %></h3>
        <span class="badge status-badge status-<%= (listing.status || 'Available').replace(/\s+/g, '').toLowerCase() %>">
          <%= listing.status || 'Available' %>
        </span>
        <% if (currentUser) { %>
          <form
            action="/listings/<%= listing._id %>/favourite/toggle"
            method="POST"
            class="d-inline js-favourite-form"
            data-listing-id="<%= listing._id %>"
            data-is-favourite="<%= isFavourite ? 'true' : 'false' %>"
          >
            <button
              type="submit"
              class="btn btn-sm <%= isFavourite ? 'btn-outline-danger' : 'btn-outline-primary' %> js-favourite-btn"
              title="<%= isFavourite ? 'Remove from favourites' : 'Add to favourites' %>"
            >
              <i class="fa-<%= isFavourite ? 'solid' : 'regular' %> fa-heart me-1 js-favourite-icon"></i>
              <span class="js-favourite-label"><%= isFavourite ? 'Remove from favourites' : 'Add to favourites' %></span>
            </button>
          </form>
        <% } %>
      </div>
      <div class="row row-cols-1 row-cols-md-2 g-3">
        <% const hasImages = listing.images && listing.images.length > 0; %>
        <% const imgList = hasImages ? listing.images : [listing.image]; %>
        <% imgList.forEach(function (img, idx) { %>
          <div class="col">
            <img
              src="<%= img %>"
              alt="Room image"
              class="img-fluid listing-gallery-img img-lightbox cursor-pointer"
              role="button"
              tabindex="0"
              data-full-src="<%= img %>"
              data-lightbox-images='<%= JSON.stringify(imgList) %>'
              data-lightbox-index="<%= idx %>"
            />
          </div>
        <% }); %>
      </div>
    </div>

    <div class="col-12 col-lg-5">
      <div class="card shadow-sm border-0">
        <div class="card-body">
          <h4 class="mb-3">&#8377; <%= listing.price ? listing.price.toLocaleString("en-IN") : '—' %> / month</h4>
          <% if (listing.averageRating || listing.rating) { %>
            <p class="text-warning mb-3">
              <% for (var i = 1; i <= 5; i++) { %>
                <i class="fa-<%= i <= Math.round(listing.averageRating || listing.rating) ? 'solid' : 'regular' %> fa-star"></i>
              <% } %>
              <span class="text-muted ms-1"><%= listing.averageRating || listing.rating %> (<%= listing.reviewCount || 0 %> reviews)</span>
            </p>
          <% } %>
          <p class="mb-2">
            <strong>Location:</strong>
            <span><%= listing.location %></span>
          </p>
          <p class="mb-2">
            <strong>Country:</strong>
            <span><%= listing.country %></span>
          </p>
          <% if (listing.locationAddress && String(listing.locationAddress).trim()) { %>
            <p class="mb-3 small text-muted">
              <i class="fa-solid fa-location-dot me-1 text-secondary"></i><%= listing.locationAddress %>
            </p>
          <% } %>
          <% if (hasMapCoords) { %>
            <div class="mb-3 p-3 rounded-4 border bg-light">
              <h6 class="fw-semibold mb-2">Exact location</h6>
              <% if (googleMapsApiKey) { %>
              <div class="mb-3" data-staybee-map-preview-wrap>
                <div class="position-relative rounded-4 overflow-hidden border bg-white">
                  <div id="staybeeMapPreview" class="staybee-map-preview-canvas"></div>
                  <div data-staybee-map-preview-loading class="staybee-map-loading d-flex align-items-center justify-content-center">
                    <div class="text-center px-3 py-4">
                      <div class="spinner-border text-secondary mb-2" role="status" aria-hidden="true"></div>
                      <p class="small text-muted mb-0">Loading map…</p>
                    </div>
                  </div>
                  <div data-staybee-map-preview-error class="alert alert-warning small mb-0 rounded-0 border-0 d-none" role="alert"></div>
                </div>
              </div>
              <% } else { %>
              <p class="small text-muted mb-2">Map preview requires <code class="small">GOOGLE_MAPS_API_KEY</code> in server environment.</p>
              <% } %>
              <a
                href="https://www.google.com/maps/search/?api=1&query=<%= encodeURIComponent(String(listing.latitude) + ',' + String(listing.longitude)) %>"
                class="btn btn-sm btn-outline-primary"
                target="_blank"
                rel="noopener noreferrer"
              >
                <i class="fa-solid fa-map-location-dot me-1"></i>Open in Google Maps
              </a>
            </div>
          <% } %>
          <% const hasOwnerContact = listing.ownerContact && listing.ownerContact.trim(); %>
          <% const hasWhatsappNumber = listing.whatsappNumber && listing.whatsappNumber.trim(); %>
          <% if (hasOwnerContact || hasWhatsappNumber) { %>
            <% const contactRaw = hasOwnerContact ? listing.ownerContact.trim() : ""; %>
            <% const whatsappRaw = hasWhatsappNumber ? listing.whatsappNumber.trim() : ""; %>
            <% const whatsappNumber = whatsappRaw.replace(/[^\d]/g, ""); %>
            <div class="mb-3">
              <% if (hasOwnerContact) { %>
                <p class="mb-2">
                  <strong>Owner Contact:</strong>
                  <a href="tel:<%= contactRaw %>" class="text-decoration-none"><%= contactRaw %></a>
                </p>
              <% } %>
              <div class="d-flex flex-wrap gap-2">
                <% if (hasOwnerContact) { %>
                  <a href="tel:<%= contactRaw %>" class="btn btn-sm btn-outline-primary">
                    <i class="fa-solid fa-phone me-1"></i>Call owner
                  </a>
                <% } %>
                <% if (hasWhatsappNumber && whatsappNumber) { %>
                  <a
                    href="https://wa.me/<%= whatsappNumber %>"
                    class="btn btn-sm btn-outline-success"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    <i class="fa-brands fa-whatsapp me-1"></i>WhatsApp
                  </a>
                <% } %>
              </div>
            </div>
          <% } %>
          <hr />
          <h5 class="mb-2">Description</h5>
          <p class="text-muted"><%= listing.description %></p>

          <hr />
          <h5 class="mb-3">Reviews</h5>
          <% if (err === 'already_reviewed') { %>
            <div class="alert alert-warning py-2 small">You have already reviewed this listing.</div>
          <% } %>
          <% if (currentUser && currentUser.role !== 'admin' && !userReview) { %>
            <form method="POST" action="/listings/<%= listing._id %>/reviews" class="mb-4">
              <div class="mb-2">
                <label class="form-label small">Your rating (1–5)</label>
                <select name="rating" class="form-select form-select-sm" style="width: auto;" required>
                  <option value="">Select...</option>
                  <option value="1">★ 1</option>
                  <option value="2">★ 2</option>
                  <option value="3">★ 3</option>
                  <option value="4">★ 4</option>
                  <option value="5">★ 5</option>
                </select>
              </div>
              <div class="mb-2">
                <label class="form-label small">Comment (optional)</label>
                <textarea name="comment" class="form-control form-control-sm" rows="2" placeholder="Share your experience..."></textarea>
              </div>
              <button type="submit" class="btn btn-sm btn-primary">Submit review</button>
            </form>
          <% } %>
          <% if (userReview) { %>
            <div class="mb-3 p-3 bg-light rounded">
              <p class="mb-1 small fw-semibold">Your review</p>
              <p class="text-warning mb-1">
                <% for (var i = 1; i <= 5; i++) { %>
                  <i class="fa-<%= i <= userReview.rating ? 'solid' : 'regular' %> fa-star"></i>
                <% } %>
              </p>
              <% if (userReview.comment) { %><p class="small text-muted mb-2"><%= userReview.comment %></p><% } %>
              <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#editReviewModal">Edit my review</button>
            </div>
          <% } %>
          <div class="reviews-list">
            <% const otherReviews = reviews ? reviews.filter(function(r) { return !userReview || r._id.toString() !== userReview._id.toString(); }) : []; %>
            <% if (otherReviews.length > 0) { %>
              <% otherReviews.forEach(function (r) { %>
                <div class="border-bottom pb-3 mb-3">
                  <p class="mb-1 small fw-semibold"><%= r.author && r.author.username ? r.author.username : 'User' %></p>
                  <p class="text-warning mb-1 small">
                    <% for (var i = 1; i <= 5; i++) { %>
                      <i class="fa-<%= i <= r.rating ? 'solid' : 'regular' %> fa-star"></i>
                    <% } %>
                    <span class="text-muted ms-1"><%= r.rating %>/5</span>
                  </p>
                  <% if (r.comment) { %><p class="small text-muted mb-0"><%= r.comment %></p><% } %>
                  <p class="small text-muted mt-1 mb-0"><%= new Date(r.createdAt).toLocaleDateString() %></p>
                </div>
              <% }); %>
            <% } else { %>
              <p class="text-muted small mb-0">No reviews yet. Be the first to review!</p>
            <% } %>
          </div>

          <% if (currentUser && currentUser.role === "admin") { %>
            <div class="d-flex gap-2 mt-4">
              <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark edit_btn">
                Edit
              </a>
              <form
                method="POST"
                action="/listings/<%= listing._id %>?_method=DELETE"
                class="d-inline"
              >
                <button class="btn btn-outline-dark dlt_btn">
                  Delete this listing
                </button>
              </form>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>

<% if (userReview) { %>
<div class="modal fade" id="editReviewModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Edit your review</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form method="POST" action="/reviews/<%= userReview._id %>?_method=PUT">
        <input type="hidden" name="_method" value="PUT" />
        <div class="modal-body">
          <div class="mb-3">
            <label class="form-label">Rating (1–5)</label>
            <select name="rating" class="form-select" required>
              <option value="1" <%= userReview.rating === 1 ? 'selected' : '' %>>★ 1</option>
              <option value="2" <%= userReview.rating === 2 ? 'selected' : '' %>>★ 2</option>
              <option value="3" <%= userReview.rating === 3 ? 'selected' : '' %>>★ 3</option>
              <option value="4" <%= userReview.rating === 4 ? 'selected' : '' %>>★ 4</option>
              <option value="5" <%= userReview.rating === 5 ? 'selected' : '' %>>★ 5</option>
            </select>
          </div>
          <div class="mb-3">
            <label class="form-label">Comment (optional)</label>
            <textarea name="comment" class="form-control" rows="3"><%= userReview.comment || '' %></textarea>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary">Save changes</button>
        </div>
      </form>
    </div>
  </div>
</div>
<% } %>

<% if (hasMapCoords && googleMapsApiKey) { %>
<script>
  window.__STAYBEE_MAP_PREVIEW__ = {
    apiKey: <%- JSON.stringify(googleMapsApiKey) %>,
    lat: <%= listing.latitude %>,
    lng: <%= listing.longitude %>
  };
</script>
<script src="/js/staybee-maps.js" defer></script>
<% } %>

<script>
  (function () {
    function updateFavouriteUI(form, isFavourite) {
      form.setAttribute("data-is-favourite", isFavourite ? "true" : "false");
      var btn = form.querySelector(".js-favourite-btn");
      var icon = form.querySelector(".js-favourite-icon");
      var label = form.querySelector(".js-favourite-label");
      if (btn) {
        btn.classList.toggle("btn-outline-danger", isFavourite);
        btn.classList.toggle("btn-outline-primary", !isFavourite);
        btn.setAttribute("title", isFavourite ? "Remove from favourites" : "Add to favourites");
      }
      if (icon) {
        icon.classList.toggle("fa-solid", isFavourite);
        icon.classList.toggle("fa-regular", !isFavourite);
      }
      if (label) {
        label.textContent = isFavourite ? "Remove from favourites" : "Add to favourites";
      }
    }

    var form = document.querySelector(".js-favourite-form");
    if (!form) return;
    form.addEventListener("submit", async function (e) {
      e.preventDefault();
      var btn = form.querySelector(".js-favourite-btn");
      if (btn) btn.disabled = true;
      try {
        var response = await fetch(form.action, {
          method: "POST",
          headers: {
            "X-Requested-With": "XMLHttpRequest",
            Accept: "application/json",
          },
        });
        if (!response.ok) throw new Error("Failed to toggle favourite");
        var data = await response.json();
        updateFavouriteUI(form, !!data.isFavourite);
      } catch (err) {
        form.submit();
      } finally {
        if (btn) btn.disabled = false;
      }
    });
  })();
</script>
