<% layout("/layouts/boilerplate") %>

<div class="listing-show-page mt-4">
  <div class="row g-4">
    <div class="col-12 col-lg-7">
      <h3 class="mb-3"><%= listing.title %></h3>
      <div class="row row-cols-1 row-cols-md-2 g-3">
        <% const hasImages = listing.images && listing.images.length > 0; %>
        <% if (hasImages) { %>
          <% listing.images.forEach(function (img) { %>
            <div class="col">
              <img
                src="<%= img %>"
                alt="Room image"
                class="img-fluid listing-gallery-img"
              />
            </div>
          <% }); %>
        <% } else { %>
          <div class="col">
            <img
              src="<%= listing.image %>"
              alt="Room image"
              class="img-fluid listing-gallery-img"
            />
          </div>
        <% } %>
      </div>
    </div>

    <div class="col-12 col-lg-5">
      <div class="card shadow-sm border-0">
        <div class="card-body">
          <h4 class="mb-3">&#8377; <%= listing.price.toLocaleString("en-IN") %> / month</h4>
          <p class="mb-2">
            <strong>Location:</strong>
            <span><%= listing.location %></span>
          </p>
          <p class="mb-3">
            <strong>Country:</strong>
            <span><%= listing.country %></span>
          </p>
          <hr />
          <h5 class="mb-2">Description</h5>
          <p class="text-muted"><%= listing.description %></p>

          <% if (currentUser && currentUser.role === "admin") { %>
            <div class="d-flex gap-2 mt-4">
              <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark edit_btn">
                Edit
              </a>
              <form
                method="POST"
                action="/listings/<%= listing._id %>?_method=DELETE"
                class="d-inline"
              >
                <button class="btn btn-outline-dark dlt_btn">
                  Delete this listing
                </button>
              </form>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>
