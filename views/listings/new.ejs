<% layout("/layouts/boilerplate") %>
<div class="row justify-content-center mt-4">
  <div class="col-12 col-md-8 col-lg-6">
    <h2 class="mb-3">Create New Listing</h2>
    <form method="POST" action="/listings" enctype="multipart/form-data" class="p-3 p-md-4 rounded-4 border bg-white shadow-sm">
      <div class="mb-3">
        <label for="title" class="form-label">Title</label>
        <br />
        <input
          name="listing[title]"
          placeholder="Enter title"
          type="text"
          class="form-control"
        />
      </div>

      <div class="mb-3">
        <label for="description" class="form-label">Description</label>
        <br />

        <textarea name="listing[description]" class="form-control"></textarea>
      </div>
      <div class="mb-3">
        <label for="images" class="form-label">Upload Images</label>
        <br />
        <input
          type="file"
          id="images"
          name="images"
          class="form-control"
          accept=".jpg,.jpeg,.png,image/jpeg,image/png"
          multiple
          required
        />
        <div class="form-text">
          You can select multiple images. Supported formats: JPG, JPEG, PNG.
        </div>
      </div>
      <div class="row">
        <div class="mb-3 col-md-4">
          <label for="price" class="form-label">Price</label>
          <br />

          <input
            name="listing[price]"
            placeholder="Enter Price"
            type="number"
            class="form-control"
          />
        </div>
        <div class="mb-3 col-md-8">
          <label for="country" class="form-label">Country</label>
          <br />

          <input
            name="listing[country]"
            placeholder="Enter country"
            type="text"
            class="form-control"
          />
        </div>
      </div>

      <div class="mb-3">
        <label for="location" class="form-label">Location</label>
        <br />

        <input
          name="listing[location]"
          placeholder="Enter Location"
          type="text"
          class="form-control"
        />
      </div>
      <div class="mb-3">
        <label for="ownerContact" class="form-label">Owner Contact Number</label>
        <input
          id="ownerContact"
          name="listing[ownerContact]"
          placeholder="Enter contact number"
          type="tel"
          class="form-control"
        />
      </div>
      <div class="mb-3">
        <label for="status" class="form-label">Availability Status</label>
        <select name="listing[status]" id="status" class="form-select">
          <option value="Available">Available</option>
          <option value="Booked">Booked</option>
          <option value="Coming Soon">Coming Soon</option>
        </select>
      </div>
      <div class="d-grid mt-3">
        <button type="submit" class="btn btn-primary">
          Create listing
        </button>
      </div>
    </form>
  </div>
</div>
