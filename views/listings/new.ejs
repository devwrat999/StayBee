<% layout("/layouts/boilerplate") %>
<div class="row">
  <div class="col-4 offset-4">
    <h2 class="ms-4 mb-3">Create New Listing</h2>
    <form method="POST" action="/listings">
      <div class="mb-3 ms-4">
        <label for="title" class="form-label">Title</label>
        <br />
        <input
          name="listing[title]"
          placeholder="Enter title"
          type="text"
          class="form-control"
        />
      </div>

      <div class="mb-3 ms-4">
        <label for="description" class="form-label">Description</label>
        <br />

        <textarea name="listing[description]" class="form-control"></textarea>
      </div>
      <div class="mb-3 ms-4">
        <label for="image" class="form-label">Image Link</label>
        <br />

        <input
          name="listing[image]"
          placeholder="Enter image URL/Link"
          class="form-control"
        />
      </div>
      <div class="row">
        <div class="mb-3 ms-4 col-md-4">
          <label for="price" class="form-label">Price</label>
          <br />

          <input
            name="listing[price]"
            placeholder="Enter Price"
            type="number"
            class="form-control"
          />
        </div>
        <div class="mb-3 ms-4 col-md-6">
          <label for="country" class="form-label">Country</label>
          <br />

          <input
            name="listing[country]"
            placeholder="Enter country"
            type="text"
            class="form-control"
          />
        </div>
      </div>

      <div class="mb-3 ms-4">
        <label for="location" class="form-label">Location</label>
        <br />

        <input
          name="listing[location]"
          placeholder="Enter Location"
          type="text"
          class="form-control"
        />
      </div>
      <br />
      <button class="btn btn-dark ms-4 add-btn">Add</button>
    </form>
  </div>
</div>
<br />
<br />
