<% layout("/layouts/boilerplate") %>

<div class="row justify-content-center mt-4">
  <div class="col-12 col-md-8 col-lg-6">
    <h2 class="mb-3">Edit Your Listing</h2>
<form
  method="POST"
  action="/listings/<%= listing._id %>?_method=PUT"
  enctype="multipart/form-data"
  class="p-3 p-md-4 rounded-4 border bg-white shadow-sm"
>
  <div class="mb-3">
    <label for="title" class="form-label">Title</label>
    <input
      name="listing[title]"
      value="<%= listing.title %>"
      type="text"
      class="form-control"
    />
  </div>
  <div class="mb-3">
    <label for="description" class="form-label">Description</label>
    <textarea name="listing[description]" class="form-control"><%= listing.description %></textarea>
  </div>

  <div class="mb-3">
    <label class="form-label">Current Images</label>
    <div class="d-flex flex-wrap gap-2" id="currentImagesGrid">
      <% if (listing.images && listing.images.length > 0) { %>
        <% listing.images.forEach(function (img) { %>
          <div class="edit-image-item mb-2" data-image-path="<%= img %>">
            <img
              src="<%= img %>"
              alt="Listing image"
              class="img-fluid"
              style="max-height: 120px; object-fit: cover;"
            />
            <button type="button" class="edit-image-delete-btn" title="Delete image" aria-label="Delete image">
              <i class="fa-solid fa-trash"></i>
            </button>
          </div>
        <% }) %>
      <% } else { %>
        <% if (listing.image) { %>
          <div class="edit-image-item mb-2" data-image-path="<%= listing.image %>">
            <img
              src="<%= listing.image %>"
              alt="Listing image"
              class="img-fluid"
              style="max-height: 120px; object-fit: cover;"
            />
            <button type="button" class="edit-image-delete-btn" title="Delete image" aria-label="Delete image">
              <i class="fa-solid fa-trash"></i>
            </button>
          </div>
        <% } %>
      <% } %>
    </div>
    <div id="noImagesText" class="text-muted small mt-2 d-none">No images left. Upload new images before saving.</div>
  </div>
  <div class="mb-3">
    <label for="images" class="form-label">Upload New Images (optional)</label>
    <input
      type="file"
      id="images"
      name="images"
      class="form-control"
      accept=".jpg,.jpeg,.png,image/jpeg,image/png"
      multiple
    />
    <div class="form-text">
      New images are added to existing ones. Use the delete icon on existing images to remove selected images.
    </div>
  </div>
  <div class="mb-3">
    <label for="price" class="form-label">Price</label>
    <input
      name="listing[price]"
      class="form-control"
      value="<%= listing.price %>"
      type="number"
    />
  </div>
  <div class="mb-3">
    <label for="country" class="form-label">Country</label>
    <input
      name="listing[country]"
      class="form-control"
      value="<%= listing.country %>"
      type="text"
    />
  </div>
  <div class="mb-3">
    <label for="location" class="form-label">Location</label>
    <input
      name="listing[location]"
      class="form-control"
      value="<%= listing.location %>"
      type="text"
    />
  </div>
  <div class="mb-3">
    <label for="status" class="form-label">Availability Status</label>
    <select name="listing[status]" id="status" class="form-select">
      <option value="Available" <%= listing.status === 'Available' ? 'selected' : '' %>>Available</option>
      <option value="Booked" <%= listing.status === 'Booked' ? 'selected' : '' %>>Booked</option>
      <option value="Coming Soon" <%= listing.status === 'Coming Soon' ? 'selected' : '' %>>Coming Soon</option>
    </select>
  </div>

  <div class="d-grid mt-3">
    <button type="submit" class="btn btn-primary btn-lg fw-semibold">Save Changes</button>
  </div>
</form>
  </div>
</div>

<script>
  (function () {
    var form = document.querySelector('form[action*="/listings/"][action*="_method=PUT"]');
    var grid = document.getElementById("currentImagesGrid");
    var noImagesText = document.getElementById("noImagesText");
    if (!form || !grid) return;

    function syncNoImagesState() {
      var visibleItems = grid.querySelectorAll(".edit-image-item");
      if (noImagesText) {
        noImagesText.classList.toggle("d-none", visibleItems.length > 0);
      }
    }

    grid.addEventListener("click", function (e) {
      var deleteBtn = e.target.closest(".edit-image-delete-btn");
      if (!deleteBtn) return;
      e.preventDefault();

      var imageItem = deleteBtn.closest(".edit-image-item");
      if (!imageItem) return;
      var imagePath = imageItem.getAttribute("data-image-path");
      if (!imagePath) return;

      var hiddenInput = document.createElement("input");
      hiddenInput.type = "hidden";
      hiddenInput.name = "deleteImages";
      hiddenInput.value = imagePath;
      form.appendChild(hiddenInput);

      imageItem.remove();
      syncNoImagesState();
    });

    syncNoImagesState();
  })();
</script>
