<% layout("/layouts/boilerplate") %>

<div class="row justify-content-center mt-4">
  <div class="col-12 col-md-8 col-lg-6">
    <h2 class="mb-3">Edit Your Listing</h2>
<form
  method="POST"
  action="/listings/<%= listing._id %>?_method=PUT"
  enctype="multipart/form-data"
  class="p-3 p-md-4 rounded-4 border bg-white shadow-sm"
>
  <div class="mb-3">
    <label for="title" class="form-label">Title</label>
    <input
      name="listing[title]"
      value="<%= listing.title %>"
      type="text"
      class="form-control"
    />
  </div>
  <div class="mb-3">
    <label for="description" class="form-label">Description</label>
    <textarea name="listing[description]" class="form-control">
<%= listing.description %></textarea
    >
  </div>

  <div class="mb-3">
    <label class="form-label">Current Images</label>
    <div class="d-flex flex-wrap gap-2">
      <% if (listing.images && listing.images.length > 0) { %>
        <% listing.images.forEach(function (img) { %>
          <img
            src="<%= img %>"
            alt="Listing image"
            class="img-fluid mb-2"
            style="max-height: 120px; object-fit: cover;"
          />
        <% }) %>
      <% } else { %>
        <img
          src="<%= listing.image %>"
          alt="Listing image"
          class="img-fluid mb-2"
          style="max-height: 120px; object-fit: cover;"
        />
      <% } %>
    </div>
  </div>
  <div class="mb-3">
    <label for="images" class="form-label">Upload New Images (optional)</label>
    <input
      type="file"
      id="images"
      name="images"
      class="form-control"
      accept=".jpg,.jpeg,.png,image/jpeg,image/png"
      multiple
    />
    <div class="form-text">
      Choose one or more images to replace the current ones. Leave empty to keep existing images.
    </div>
  </div>
  <div class="mb-3">
    <label for="price" class="form-label">Price</label>
    <input
      name="listing[price]"
      class="form-control"
      value="<%= listing.price %>"
      type="number"
    />
  </div>
  <div class="mb-3">
    <label for="country" class="form-label">Country</label>
    <input
      name="listing[country]"
      class="form-control"
      value="<%= listing.country %>"
      type="text"
    />
  </div>
  <div class="mb-3">
    <label for="location" class="form-label">Location</label>
    <input
      name="listing[location]"
      class="form-control"
      value="<%= listing.location %>"
      type="text"
    />
  </div>

  <button class="btn edit-btn">Save</button>
</form>
  </div>
</div>
