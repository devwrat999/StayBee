<% layout("/layouts/boilerplate") %>

<div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mt-3">
  <div>
    <h3 class="mb-0">Stays nearby</h3>
    <p class="text-muted mb-0" style="font-size: 0.9rem;">
      Explore rooms and apartments tailored for your next stay.
    </p>
  </div>
  <div class="d-flex align-items-center gap-2 flex-wrap justify-content-end">
    <div class="d-flex align-items-center gap-2 flex-wrap">
      <button type="button" class="btn btn-sm btn-outline-primary" id="nearMeBtn">
        Near me
      </button>
      <button type="button" class="btn btn-sm btn-outline-secondary" id="showAllBtn">
        Show all
      </button>
      <button
        type="button"
        class="btn btn-sm btn-outline-dark"
        data-bs-toggle="modal"
        data-bs-target="#changeLocationModal"
        id="changeLocationBtn"
      >
        Change location
      </button>
      <span class="small text-muted" id="activeLocationLabel" style="max-width: 320px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"></span>
    </div>

    <form method="GET" action="/listings" class="d-flex align-items-center gap-2">
      <input type="hidden" name="minPrice" value="<%= typeof filters !== 'undefined' ? (filters.minPrice || '') : '' %>" />
      <input type="hidden" name="maxPrice" value="<%= typeof filters !== 'undefined' ? (filters.maxPrice || '') : '' %>" />
      <input type="hidden" name="location" value="<%= typeof filters !== 'undefined' ? (filters.location || '') : '' %>" />
      <input type="hidden" name="lat" value="<%= typeof filters !== 'undefined' ? (filters.lat || '') : '' %>" />
      <input type="hidden" name="lng" value="<%= typeof filters !== 'undefined' ? (filters.lng || '') : '' %>" />
      <input type="hidden" name="radiusKm" value="<%= typeof filters !== 'undefined' ? (filters.radiusKm || '') : '' %>" />
      <input type="hidden" name="nearTried" value="1" />
      <label for="sortSelect" class="form-label mb-0 small text-muted">Sort:</label>
      <select
        name="sort"
        id="sortSelect"
        class="form-select form-select-sm sort-select-btn"
        style="width: auto;"
        onchange="this.form.submit()"
      >
        <option value="">Default</option>
        <option value="price_asc" <%= (typeof filters !== 'undefined' && filters.sort === 'price_asc') ? 'selected' : '' %>>Low to High</option>
        <option value="price_desc" <%= (typeof filters !== 'undefined' && filters.sort === 'price_desc') ? 'selected' : '' %>>High to Low</option>
      </select>
    </form>
  </div>
</div>

<!-- Change location modal (manual coordinates) -->
<div class="modal fade" id="changeLocationModal" tabindex="-1" aria-labelledby="changeLocationModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="changeLocationModalLabel">Change location</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <p class="text-muted small mb-3">
          Type an address/place to see listings near that location (useful if you want to search near another city).
        </p>
        <div class="row g-2">
          <div class="col-12">
            <label class="form-label small mb-1" for="manualAddress">Address / Place</label>
            <input
              type="text"
              class="form-control form-control-sm"
              id="manualAddress"
              placeholder="e.g. Dehradun, India or Graphic Era University"
              autocomplete="street-address"
            />
            <div class="form-text">We’ll convert this address to coordinates automatically.</div>
          </div>
          <div class="col-12">
            <label class="form-label small mb-1" for="manualRadius">Radius (km)</label>
            <input type="number" min="1" max="200" step="1" class="form-control form-control-sm" id="manualRadius" placeholder="25" />
            <div class="form-text">Default: 25km (max 200km)</div>
          </div>
        </div>
        <div class="d-flex gap-2 flex-wrap mt-3">
          <button type="button" class="btn btn-sm btn-outline-primary" id="useCurrentInModalBtn">Use current location</button>
          <button type="button" class="btn btn-sm btn-outline-secondary" id="clearManualBtn">Clear</button>
        </div>
        <div class="alert alert-danger py-2 mt-3 d-none" id="manualLocError" role="alert"></div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-sm btn-primary" id="applyManualBtn">Apply</button>
      </div>
    </div>
  </div>
</div>

<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-3 g-md-4 mt-3" id="listing-grid">
  <% if (allListing && allListing.length > 0) { %>
    <% allListing.forEach(function (listing) { %>
      <% const isFav = (typeof userFavouriteIds !== 'undefined' && userFavouriteIds) ? userFavouriteIds.includes(listing._id.toString()) : false; %>
      <% const statusText = listing.status || 'Available'; %>
      <% const statusClass = statusText === 'Available' ? 'status-available' : (statusText === 'Booked' ? 'status-booked' : 'status-comingsoon'); %>
      <div class="col">
        <a
          href="/listings/<%= listing._id %>"
          class="listing-link text-decoration-none text-dark"
        >
          <div class="card listing-card h-100 position-relative">
            <span class="badge position-absolute top-0 start-0 m-2 status-badge <%= statusClass %>">
              <%= statusText %>
            </span>
            <% if (currentUser) { %>
              <form
                action="/listings/<%= listing._id %>/favourite/toggle"
                method="POST"
                class="position-absolute top-0 end-0 m-2 js-favourite-form"
                style="z-index: 5;"
                data-listing-id="<%= listing._id %>"
                data-is-favourite="<%= isFav ? 'true' : 'false' %>"
              >
                <button
                  type="submit"
                  class="btn btn-sm btn-light rounded-circle p-2 shadow-sm js-favourite-btn"
                  onclick="event.stopPropagation();"
                  title="<%= isFav ? 'Remove from favourites' : 'Add to favourites' %>"
                >
                  <i class="fa-<%= isFav ? 'solid' : 'regular' %> fa-heart <%= isFav ? 'text-danger' : '' %> js-favourite-icon"></i>
                </button>
              </form>
            <% } %>
            <div
              id="carousel-<%= listing._id %>"
              class="carousel slide"
              data-bs-ride="carousel"
              data-bs-interval="5000"
            >
              <div class="carousel-inner">
                <% const hasImages = listing.images && listing.images.length > 0; %>
                <% const imgList = hasImages ? listing.images : [listing.image]; %>
                <% imgList.forEach(function (img, idx) { %>
                  <div class="carousel-item <%= idx === 0 ? 'active' : '' %>">
                    <img
                      src="<%= img %>"
                      class="d-block w-100 img-lightbox-card listing-card-img"
                      alt="listing_image"
                      data-images='<%= JSON.stringify(imgList) %>'
                      data-index="<%= idx %>"
                    />
                  </div>
                <% }) %>
              </div>

              <% if (imgList.length > 1) { %>
                <button
                  class="carousel-control-prev"
                  type="button"
                  data-bs-target="#carousel-<%= listing._id %>"
                  data-bs-slide="prev"
                  style="width: 12%;"
                >
                  <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                  <span class="visually-hidden">Previous</span>
                </button>
                <button
                  class="carousel-control-next"
                  type="button"
                  data-bs-target="#carousel-<%= listing._id %>"
                  data-bs-slide="next"
                  style="width: 12%;"
                >
                  <span class="carousel-control-next-icon" aria-hidden="true"></span>
                  <span class="visually-hidden">Next</span>
                </button>
              <% } %>
            </div>

            <div class="card-body">
              <p class="card-text mb-1 d-flex align-items-center gap-2 flex-wrap">
                <b><%= listing.title %></b>
                <span class="status-dot <%= statusClass %>" aria-label="<%= statusText %>" title="<%= statusText %>"></span>
              </p>
              <% if (listing.averageRating || listing.rating) { %>
                <% const avgRating = listing.averageRating || listing.rating; %>
                <% const totalReviews = listing.reviewCount || (listing.rating ? 1 : 0); %>
                <p class="card-text mb-1 text-warning small">
                  <span class="text-muted me-1"><%= avgRating %></span>
                  <% for (var i = 1; i <= 5; i++) { %>
                    <i class="fa-<%= i <= Math.round(avgRating) ? 'solid' : 'regular' %> fa-star"></i>
                  <% } %>
                  <span class="text-muted ms-1">(<%= totalReviews %> <%= totalReviews === 1 ? 'review' : 'reviews' %>)</span>
                </p>
              <% } %>
              <p class="card-text">
                &#8377;
                <%= listing.price ? listing.price.toLocaleString("en-IN") : '—' %>
                / month
              </p>
            </div>
          </div>
        </a>
      </div>
    <% }); %>
  <% } else { %>
    <div class="col">
      <p>No listings match your search. Try adjusting the price range or location (for example, "Graphic Era Hill University").</p>
    </div>
  <% } %>
</div>

<script>
  (function () {
    // Auto-detect user's location (if allowed) and show nearby listings.
    // If permission is denied or unavailable, we keep existing "show all listings" behavior.
    try {
      var url = new URL(window.location.href);
      var alreadyHasCoords = url.searchParams.get("lat") && url.searchParams.get("lng");
      var alreadyTried = url.searchParams.get("nearTried") === "1";
      var mode = null;
      try {
        mode = localStorage.getItem("staybeeListingsMode");
      } catch (e) {}

      if (!alreadyHasCoords && !alreadyTried && mode !== "all" && navigator.geolocation) {
        navigator.geolocation.getCurrentPosition(
          function (pos) {
            try {
              var u = new URL(window.location.href);
              u.searchParams.set("lat", String(pos.coords.latitude));
              u.searchParams.set("lng", String(pos.coords.longitude));
              if (!u.searchParams.get("radiusKm")) u.searchParams.set("radiusKm", "25");
              u.searchParams.set("nearTried", "1");
              try {
                localStorage.setItem("staybeeListingsMode", "near");
                localStorage.setItem("staybeeLastLat", String(pos.coords.latitude));
                localStorage.setItem("staybeeLastLng", String(pos.coords.longitude));
              } catch (e) {}
              window.location.replace(u.toString());
            } catch (e) {}
          },
          function () {
            try {
              var u2 = new URL(window.location.href);
              u2.searchParams.set("nearTried", "1");
              window.history.replaceState(null, "", u2.toString());
            } catch (e) {}
          },
          { enableHighAccuracy: false, timeout: 5000, maximumAge: 600000 },
        );
      }
    } catch (e) {}

    function setLabel() {
      var el = document.getElementById("activeLocationLabel");
      if (!el) return;
      try {
        var u = new URL(window.location.href);
        var lat = u.searchParams.get("lat");
        var lng = u.searchParams.get("lng");
        var radiusKm = u.searchParams.get("radiusKm");
        var nearAddr = u.searchParams.get("nearAddr");
        if (lat && lng) {
          var r = radiusKm || "25";
          if (nearAddr) {
            el.textContent = "Near: " + nearAddr + " (" + r + "km)";
          } else {
            el.textContent =
              "Near: " +
              Number(lat).toFixed(4) +
              ", " +
              Number(lng).toFixed(4) +
              " (" +
              r +
              "km)";
          }
        } else {
          el.textContent = "Showing: All listings";
        }
      } catch (e) {}
    }
    setLabel();

    function applyCoords(lat, lng, radiusKm, nearAddr) {
      var u = new URL(window.location.href);
      u.searchParams.set("lat", String(lat));
      u.searchParams.set("lng", String(lng));
      u.searchParams.set("radiusKm", String(radiusKm || 25));
      u.searchParams.set("nearTried", "1");
      if (nearAddr && String(nearAddr).trim() !== "") {
        u.searchParams.set("nearAddr", String(nearAddr).trim());
      } else {
        u.searchParams.delete("nearAddr");
      }
      try {
        localStorage.setItem("staybeeListingsMode", "near");
        localStorage.setItem("staybeeLastLat", String(lat));
        localStorage.setItem("staybeeLastLng", String(lng));
        localStorage.setItem("staybeeLastRadiusKm", String(radiusKm || 25));
        if (nearAddr && String(nearAddr).trim() !== "") {
          localStorage.setItem("staybeeLastNearAddr", String(nearAddr).trim());
        }
      } catch (e) {}
      window.location.assign(u.toString());
    }

    function clearCoordsShowAll() {
      var u = new URL(window.location.href);
      u.searchParams.delete("lat");
      u.searchParams.delete("lng");
      u.searchParams.delete("radiusKm");
      u.searchParams.delete("nearAddr");
      u.searchParams.set("nearTried", "1");
      try {
        localStorage.setItem("staybeeListingsMode", "all");
      } catch (e) {}
      window.location.assign(u.toString());
    }

    var nearMeBtn = document.getElementById("nearMeBtn");
    if (nearMeBtn) {
      nearMeBtn.addEventListener("click", function () {
        if (!navigator.geolocation) return;
        navigator.geolocation.getCurrentPosition(
          function (pos) {
            applyCoords(pos.coords.latitude, pos.coords.longitude, 25, "Current location");
          },
          function () {
            // If blocked, keep current behavior (all listings).
            try {
              localStorage.setItem("staybeeListingsMode", "all");
            } catch (e) {}
            setLabel();
          },
          { enableHighAccuracy: false, timeout: 7000, maximumAge: 600000 },
        );
      });
    }

    var showAllBtn = document.getElementById("showAllBtn");
    if (showAllBtn) {
      showAllBtn.addEventListener("click", function () {
        clearCoordsShowAll();
      });
    }

    // Prefill modal with current/last-known values
    var manualAddress = document.getElementById("manualAddress");
    var manualRadius = document.getElementById("manualRadius");
    var manualErr = document.getElementById("manualLocError");
    function showManualErr(msg) {
      if (!manualErr) return;
      manualErr.textContent = msg;
      manualErr.classList.remove("d-none");
    }
    function clearManualErr() {
      if (!manualErr) return;
      manualErr.textContent = "";
      manualErr.classList.add("d-none");
    }

    function prefillModal() {
      clearManualErr();
      try {
        var u = new URL(window.location.href);
        var nearAddr = u.searchParams.get("nearAddr");
        var r = u.searchParams.get("radiusKm");
        if (!r) {
          try {
            r = localStorage.getItem("staybeeLastRadiusKm") || "25";
          } catch (e) {
            r = "25";
          }
        }
        if (!nearAddr) {
          try {
            nearAddr = localStorage.getItem("staybeeLastNearAddr") || "";
          } catch (e) {}
        }
        if (manualAddress) manualAddress.value = nearAddr || "";
        if (manualRadius) manualRadius.value = r || "25";
      } catch (e) {}
    }
    prefillModal();

    var changeLocationBtn = document.getElementById("changeLocationBtn");
    if (changeLocationBtn) {
      changeLocationBtn.addEventListener("click", function () {
        prefillModal();
      });
    }

    var clearManualBtn = document.getElementById("clearManualBtn");
    if (clearManualBtn) {
      clearManualBtn.addEventListener("click", function () {
        clearManualErr();
        if (manualAddress) manualAddress.value = "";
        if (manualRadius) manualRadius.value = "25";
      });
    }

    var useCurrentInModalBtn = document.getElementById("useCurrentInModalBtn");
    if (useCurrentInModalBtn) {
      useCurrentInModalBtn.addEventListener("click", function () {
        clearManualErr();
        if (!navigator.geolocation) return;
        navigator.geolocation.getCurrentPosition(
          function (pos) {
            if (manualAddress) manualAddress.value = "Current location";
            if (manualRadius && !manualRadius.value) manualRadius.value = "25";
            try {
              localStorage.setItem("staybeeLastLat", String(pos.coords.latitude));
              localStorage.setItem("staybeeLastLng", String(pos.coords.longitude));
              localStorage.setItem("staybeeLastNearAddr", "Current location");
            } catch (e) {}
          },
          function () {
            showManualErr("Location access denied. Please type an address/place.");
          },
          { enableHighAccuracy: false, timeout: 7000, maximumAge: 600000 },
        );
      });
    }

    function parseNum(v) {
      var n = parseFloat(String(v || "").trim());
      return Number.isFinite(n) ? n : null;
    }

    async function geocodeAddressToLatLng(address) {
      var q = String(address || "").trim();
      if (!q) throw new Error("Please type an address/place.");
      // Nominatim (OpenStreetMap) geocoding - lightweight and keyless.
      // Note: public service has rate limits; for heavy usage, move this to server with an API key provider.
      var endpoint =
        "https://nominatim.openstreetmap.org/search?format=json&limit=1&q=" +
        encodeURIComponent(q);
      var resp = await fetch(endpoint, {
        method: "GET",
        headers: { Accept: "application/json" },
      });
      if (!resp.ok) throw new Error("Unable to lookup address right now.");
      var data = await resp.json();
      if (!Array.isArray(data) || !data.length) throw new Error("No results found. Try a more specific address.");
      var first = data[0];
      var lat = parseFloat(first.lat);
      var lng = parseFloat(first.lon);
      if (!Number.isFinite(lat) || !Number.isFinite(lng)) throw new Error("Invalid geocoding response.");
      var label = (first.display_name || q).toString();
      return { lat: lat, lng: lng, label: label };
    }

    var applyManualBtn = document.getElementById("applyManualBtn");
    if (applyManualBtn) {
      applyManualBtn.addEventListener("click", async function () {
        clearManualErr();
        var r = parseNum(manualRadius ? manualRadius.value : "") || 25;
        r = Math.max(1, Math.min(200, r));
        var addr = manualAddress ? manualAddress.value : "";

        // Special case: if user selected "Current location" in the address box.
        if (String(addr).trim().toLowerCase() === "current location") {
          try {
            var lastLat = parseFloat(localStorage.getItem("staybeeLastLat") || "");
            var lastLng = parseFloat(localStorage.getItem("staybeeLastLng") || "");
            if (Number.isFinite(lastLat) && Number.isFinite(lastLng)) {
              return applyCoords(lastLat, lastLng, r, "Current location");
            }
          } catch (e) {}
          if (!navigator.geolocation) return showManualErr("Geolocation not available on this device.");
          try {
            var pos = await new Promise(function (resolve, reject) {
              navigator.geolocation.getCurrentPosition(resolve, reject, {
                enableHighAccuracy: false,
                timeout: 7000,
                maximumAge: 600000,
              });
            });
            return applyCoords(pos.coords.latitude, pos.coords.longitude, r, "Current location");
          } catch (e) {
            return showManualErr("Location access denied. Please type an address/place.");
          }
        }

        try {
          applyManualBtn.disabled = true;
          var geo = await geocodeAddressToLatLng(addr);
          applyCoords(geo.lat, geo.lng, r, geo.label);
        } catch (err) {
          showManualErr((err && err.message) ? err.message : "Unable to apply location.");
        } finally {
          applyManualBtn.disabled = false;
        }
      });
    }

    document.querySelectorAll(".img-lightbox-card").forEach(function (imgEl) {
      imgEl.addEventListener("click", function (e) {
        e.preventDefault();
        e.stopPropagation();
        var images = JSON.parse(this.getAttribute("data-images") || "[]");
        var index = parseInt(this.getAttribute("data-index") || "0", 10);
        if (window.openImageLightbox) {
          window.openImageLightbox(images, index);
        }
      });
    });

    function updateFavouriteUI(form, isFavourite) {
      form.setAttribute("data-is-favourite", isFavourite ? "true" : "false");
      var btn = form.querySelector(".js-favourite-btn");
      var icon = form.querySelector(".js-favourite-icon");
      if (btn) {
        btn.setAttribute("title", isFavourite ? "Remove from favourites" : "Add to favourites");
      }
      if (icon) {
        icon.classList.toggle("fa-solid", isFavourite);
        icon.classList.toggle("fa-regular", !isFavourite);
        icon.classList.toggle("text-danger", isFavourite);
      }
    }

    document.querySelectorAll(".js-favourite-form").forEach(function (form) {
      form.addEventListener("submit", async function (e) {
        e.preventDefault();
        var btn = form.querySelector(".js-favourite-btn");
        if (btn) btn.disabled = true;
        try {
          var response = await fetch(form.action, {
            method: "POST",
            headers: {
              "X-Requested-With": "XMLHttpRequest",
              Accept: "application/json",
            },
          });
          if (!response.ok) throw new Error("Failed to toggle favourite");
          var data = await response.json();
          updateFavouriteUI(form, !!data.isFavourite);
        } catch (err) {
          form.submit();
        } finally {
          if (btn) btn.disabled = false;
        }
      });
    });
  })();
</script>
