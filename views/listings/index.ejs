<% layout("/layouts/boilerplate") %>

<div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mt-3">
  <div>
    <h3 class="mb-0">Stays nearby</h3>
    <p class="text-muted mb-0" style="font-size: 0.9rem;">
      Explore rooms and apartments tailored for your next stay.
    </p>
  </div>
  <form method="GET" action="/listings" class="d-flex align-items-center gap-2">
    <input type="hidden" name="minPrice" value="<%= typeof filters !== 'undefined' ? (filters.minPrice || '') : '' %>" />
    <input type="hidden" name="maxPrice" value="<%= typeof filters !== 'undefined' ? (filters.maxPrice || '') : '' %>" />
    <input type="hidden" name="location" value="<%= typeof filters !== 'undefined' ? (filters.location || '') : '' %>" />
    <label for="sortSelect" class="form-label mb-0 small text-muted">Sort:</label>
    <select name="sort" id="sortSelect" class="form-select form-select-sm" style="width: auto;" onchange="this.form.submit()">
      <option value="">Default</option>
      <option value="price_asc" <%= (typeof filters !== 'undefined' && filters.sort === 'price_asc') ? 'selected' : '' %>>Low to High</option>
      <option value="price_desc" <%= (typeof filters !== 'undefined' && filters.sort === 'price_desc') ? 'selected' : '' %>>High to Low</option>
    </select>
  </form>
</div>

<div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3" id="listing-grid">
  <% if (allListing && allListing.length > 0) { %>
    <% allListing.forEach(function (listing) { %>
      <% const isFav = (typeof userFavouriteIds !== 'undefined' && userFavouriteIds) ? userFavouriteIds.includes(listing._id.toString()) : false; %>
      <% const statusText = listing.status || 'Available'; %>
      <% const statusClass = statusText === 'Available' ? 'status-available' : (statusText === 'Booked' ? 'status-booked' : 'status-comingsoon'); %>
      <div class="col mb-4">
        <a
          href="/listings/<%= listing._id %>"
          class="listing-link text-decoration-none text-dark"
        >
          <div class="card h-100 position-relative">
            <span class="badge position-absolute top-0 start-0 m-2 status-badge <%= statusClass %>">
              <%= statusText %>
            </span>
            <% if (currentUser) { %>
              <form
                action="/listings/<%= listing._id %>/favourite/toggle"
                method="POST"
                class="position-absolute top-0 end-0 m-2 js-favourite-form"
                style="z-index: 5;"
                data-listing-id="<%= listing._id %>"
                data-is-favourite="<%= isFav ? 'true' : 'false' %>"
              >
                <button
                  type="submit"
                  class="btn btn-sm btn-light rounded-circle p-2 shadow-sm js-favourite-btn"
                  onclick="event.stopPropagation();"
                  title="<%= isFav ? 'Remove from favourites' : 'Add to favourites' %>"
                >
                  <i class="fa-<%= isFav ? 'solid' : 'regular' %> fa-heart <%= isFav ? 'text-danger' : '' %> js-favourite-icon"></i>
                </button>
              </form>
            <% } %>
            <div
              id="carousel-<%= listing._id %>"
              class="carousel slide"
              data-bs-ride="carousel"
              data-bs-interval="5000"
            >
              <div class="carousel-inner">
                <% const hasImages = listing.images && listing.images.length > 0; %>
                <% const imgList = hasImages ? listing.images : [listing.image]; %>
                <% imgList.forEach(function (img, idx) { %>
                  <div class="carousel-item <%= idx === 0 ? 'active' : '' %>">
                    <img
                      src="<%= img %>"
                      class="d-block w-100 img-lightbox-card"
                      alt="listing_image"
                      style="height: 15rem; object-fit: cover;"
                      data-images='<%= JSON.stringify(imgList) %>'
                      data-index="<%= idx %>"
                      onclick="event.preventDefault(); event.stopPropagation(); window.openImageLightbox(JSON.parse(this.getAttribute('data-images')), <%= idx %>);"
                    />
                  </div>
                <% }) %>
              </div>

              <% if (imgList.length > 1) { %>
                <button
                  class="carousel-control-prev"
                  type="button"
                  data-bs-target="#carousel-<%= listing._id %>"
                  data-bs-slide="prev"
                  style="width: 12%;"
                >
                  <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                  <span class="visually-hidden">Previous</span>
                </button>
                <button
                  class="carousel-control-next"
                  type="button"
                  data-bs-target="#carousel-<%= listing._id %>"
                  data-bs-slide="next"
                  style="width: 12%;"
                >
                  <span class="carousel-control-next-icon" aria-hidden="true"></span>
                  <span class="visually-hidden">Next</span>
                </button>
              <% } %>
            </div>

            <div class="card-body">
              <p class="card-text mb-1 d-flex align-items-center gap-2 flex-wrap">
                <b><%= listing.title %></b>
                <span class="status-dot <%= statusClass %>" aria-label="<%= statusText %>" title="<%= statusText %>"></span>
              </p>
              <% if (listing.averageRating || listing.rating) { %>
                <% const avgRating = listing.averageRating || listing.rating; %>
                <% const totalReviews = listing.reviewCount || (listing.rating ? 1 : 0); %>
                <p class="card-text mb-1 text-warning small">
                  <span class="text-muted me-1"><%= avgRating %></span>
                  <% for (var i = 1; i <= 5; i++) { %>
                    <i class="fa-<%= i <= Math.round(avgRating) ? 'solid' : 'regular' %> fa-star"></i>
                  <% } %>
                  <span class="text-muted ms-1">(<%= totalReviews %> <%= totalReviews === 1 ? 'review' : 'reviews' %>)</span>
                </p>
              <% } %>
              <p class="card-text">
                &#8377;
                <%= listing.price ? listing.price.toLocaleString("en-IN") : '—' %>
                / month
              </p>
            </div>
          </div>
        </a>
      </div>
    <% }); %>
  <% } else { %>
    <div class="col">
      <p>No listings match your search. Try adjusting the price range or location (for example, "Graphic Era Hill University").</p>
    </div>
  <% } %>
</div>

<script>
  (function () {
    function updateFavouriteUI(form, isFavourite) {
      form.setAttribute("data-is-favourite", isFavourite ? "true" : "false");
      var btn = form.querySelector(".js-favourite-btn");
      var icon = form.querySelector(".js-favourite-icon");
      if (btn) {
        btn.setAttribute("title", isFavourite ? "Remove from favourites" : "Add to favourites");
      }
      if (icon) {
        icon.classList.toggle("fa-solid", isFavourite);
        icon.classList.toggle("fa-regular", !isFavourite);
        icon.classList.toggle("text-danger", isFavourite);
      }
    }

    document.querySelectorAll(".js-favourite-form").forEach(function (form) {
      form.addEventListener("submit", async function (e) {
        e.preventDefault();
        var btn = form.querySelector(".js-favourite-btn");
        if (btn) btn.disabled = true;
        try {
          var response = await fetch(form.action, {
            method: "POST",
            headers: {
              "X-Requested-With": "XMLHttpRequest",
              Accept: "application/json",
            },
          });
          if (!response.ok) throw new Error("Failed to toggle favourite");
          var data = await response.json();
          updateFavouriteUI(form, !!data.isFavourite);
        } catch (err) {
          form.submit();
        } finally {
          if (btn) btn.disabled = false;
        }
      });
    });
  })();
</script>
