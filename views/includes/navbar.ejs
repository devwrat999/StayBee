<nav class="navbar staybee-navbar sticky-top">
  <div class="container-fluid px-3 px-md-4">
    <div class="staybee-navbar-inner d-flex flex-nowrap align-items-center w-100 gap-2">
      <a class="navbar-brand d-flex align-items-center flex-shrink-0 me-0" href="<%= currentUser ? '/listings' : '/login' %>">
        <img src="/assets/staybee-logo.png" alt="StayBee logo" class="navbar-logo-img" />
      </a>

      <% if (!hideSearch) { %>
        <button
          type="button"
          class="search-trigger staybee-search-desktop d-none d-md-inline-flex flex-shrink-0"
          data-bs-toggle="modal"
          data-bs-target="#searchModal"
        >
          <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
          <span>Search</span>
        </button>
      <% } %>

      <div class="staybee-navbar-links flex-grow-1 min-w-0">
        <nav class="navbar-nav staybee-navbar-nav d-flex flex-row flex-nowrap align-items-center gap-1 gap-md-2">
          <a class="nav-link staybee-nav-link flex-shrink-0" href="/">Home</a>
        </nav>
      </div>

      <div class="staybee-navbar-actions d-flex align-items-center gap-2 flex-shrink-0">
        <% if (!hideSearch) { %>
          <button
            type="button"
            class="search-trigger d-inline-flex d-md-none flex-shrink-0"
            data-bs-toggle="modal"
            data-bs-target="#searchModal"
          >
            <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
            <span>Search</span>
          </button>
        <% } %>
        <% if (currentUser) { %>
          <button
            type="button"
            class="staybee-hamburger-btn"
            data-bs-toggle="offcanvas"
            data-bs-target="#userMenuCanvas"
            aria-controls="userMenuCanvas"
            aria-label="Open account menu"
          >
            <i class="fa-solid fa-bars" aria-hidden="true"></i>
          </button>
        <% } %>
      </div>
    </div>
  </div>
</nav>

<% if (currentUser) { %>
  <div
    class="offcanvas offcanvas-end user-menu-canvas"
    tabindex="-1"
    id="userMenuCanvas"
    aria-labelledby="userMenuCanvasLabel"
    data-bs-scroll="false"
    data-bs-backdrop="true"
  >
    <div class="offcanvas-header border-bottom">
      <h5 class="offcanvas-title mb-0" id="userMenuCanvasLabel">Account</h5>
      <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>
    <div class="offcanvas-body">
      <p class="menu-user-label mb-3">
        <%= currentUser.name %><%= currentUser.role === "admin" ? " (Admin)" : "" %>
      </p>
      
      <!-- jiya: Navigation menu items -->
      <div class="menu-navigation mb-4">
        <h6 class="text-muted small mb-3">Navigation</h6>
        <div class="list-group list-group-flush">
          <a href="/listings" class="list-group-item list-group-item-action">
            <i class="fa-solid fa-home me-2"></i>Browse Listings
          </a>
          <a href="/favourites" class="list-group-item list-group-item-action">
            <i class="fa-regular fa-heart me-2"></i>My Favourites
          </a>
          <% if (currentUser.role === "user") { %>
            <a href="/my-listings" class="list-group-item list-group-item-action">
              <i class="fa-solid fa-list me-2"></i>My Listings
            </a>
            <a href="/listings/new" class="list-group-item list-group-item-action">
              <i class="fa-solid fa-plus me-2"></i>Add New Listing
            </a>
          <% } %>
          <% if (currentUser.role === "admin") { %>
            <a href="/admin/pending-listings" class="list-group-item list-group-item-action">
              <i class="fa-solid fa-clock me-2"></i>Pending Approvals
            </a>
            <a href="/admin/approved-listings" class="list-group-item list-group-item-action">
              <i class="fa-solid fa-check-circle me-2"></i>Approved History
            </a>
            <a href="/admin/rejected-listings" class="list-group-item list-group-item-action">
              <i class="fa-solid fa-times me-2"></i>Rejected Listings
            </a>
          <% } %>
        </div>
      </div>
      
      <form method="POST" action="/logout" class="menu-logout-form">
        <button type="submit" class="btn btn-outline-secondary menu-logout-btn w-100">Logout</button>
      </form>
    </div>
  </div>
<% } %>
