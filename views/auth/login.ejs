<% layout("/layouts/boilerplate") %>

<style>
  body {
    background:
      radial-gradient(circle at 18% 22%, rgba(88, 119, 181, 0.2) 0%, rgba(88, 119, 181, 0) 40%),
      radial-gradient(circle at 82% 78%, rgba(72, 177, 166, 0.16) 0%, rgba(72, 177, 166, 0) 42%),
      linear-gradient(145deg, #070b13 0%, #0a1020 45%, #080c16 100%);
    color: #e6edf7;
  }

  .navbar,
  .f-info {
    display: none !important;
  }

  .login-lamp-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.25rem 0;
  }

  .lamp-scene {
    --scene-bg: #0a0f1a;
    --scene-bg-active: #111a26;
    width: 100%;
    max-width: 980px;
    min-height: 560px;
    border-radius: 1.1rem;
    position: relative;
    overflow: hidden;
    background: radial-gradient(circle at 25% 35%, #111a27 0%, var(--scene-bg) 55%, #060a12 100%);
    transition: background 0.5s ease, box-shadow 0.5s ease;
    border: 1px solid rgba(162, 188, 226, 0.16);
    box-shadow: 0 20px 55px rgba(3, 7, 16, 0.6);
  }

  .lamp-scene.active {
    background: radial-gradient(circle at 28% 35%, rgba(255, 223, 130, 0.24) 0%, var(--scene-bg-active) 50%, #09101a 100%);
  }

  .lamp-instruction {
    position: absolute;
    top: 1.25rem;
    left: 50%;
    transform: translateX(-50%) translateY(0);
    margin: 0;
    color: rgba(226, 236, 250, 0.86);
    font-size: clamp(0.84rem, 1.15vw, 0.96rem);
    font-weight: 500;
    letter-spacing: 0.015em;
    line-height: 1.3;
    text-align: center;
    padding: 0.3rem 0.8rem;
    border-radius: 999px;
    background: rgba(20, 30, 45, 0.35);
    border: 1px solid rgba(171, 194, 222, 0.2);
    backdrop-filter: blur(6px);
    transition: opacity 0.35s ease, transform 0.35s ease;
    opacity: 1;
    z-index: 4;
    pointer-events: none;
  }

  .lamp-scene.active .lamp-instruction {
    opacity: 0;
    transform: translateX(-50%) translateY(-12px);
  }

  .lamp-wrap {
    position: absolute;
    left: 8%;
    top: 22%;
    width: 220px;
    height: 320px;
    pointer-events: none;
  }

  .lamp-shade {
    width: 150px;
    height: 72px;
    background: #f2f3ef;
    border-radius: 78px 78px 18px 18px;
    margin: 0 auto;
    box-shadow: 0 0 16px rgba(255, 255, 255, 0.2);
  }

  .lamp-stand {
    width: 12px;
    height: 148px;
    background: #edece7;
    margin: 0.5rem auto 0;
    border-radius: 8px;
  }

  .lamp-base {
    width: 94px;
    height: 11px;
    border-radius: 999px;
    background: #ecebe7;
    margin: 0.4rem auto 0;
  }

  .lamp-glow {
    position: absolute;
    top: -4%;
    left: -20%;
    width: 350px;
    height: 350px;
    background: radial-gradient(circle, rgba(255, 225, 130, 0.36) 0%, rgba(255, 225, 130, 0.12) 34%, rgba(255, 225, 130, 0) 72%);
    opacity: 0;
    transition: opacity 0.5s ease;
    pointer-events: none;
  }

  .lamp-scene.active .lamp-glow {
    opacity: 1;
  }

  .pull-cord {
    position: absolute;
    left: calc(8% + 124px);
    top: 23%;
    width: 24px;
    height: 130px;
    background: linear-gradient(
      to right,
      transparent calc(50% - 1px),
      rgba(220, 220, 220, 0.9) calc(50% - 1px),
      rgba(220, 220, 220, 0.9) calc(50% + 1px),
      transparent calc(50% + 1px)
    );
    --pull-y: 0px;
    transform: translateY(var(--pull-y));
    transition: transform 0.2s ease;
    z-index: 3;
    touch-action: none;
    cursor: grab;
  }

  .cord-knob {
    position: absolute;
    bottom: -9px;
    left: 50%;
    width: 18px;
    height: 18px;
    transform: translateX(-50%);
    border-radius: 50%;
    border: 0;
    background: radial-gradient(circle at 35% 35%, #fff2cf 0%, #c9b18b 70%);
    box-shadow: 0 0 4px rgba(255, 213, 132, 0.55);
    cursor: grab;
  }

  .login-form-panel {
    position: absolute;
    right: 8%;
    top: 50%;
    transform: translateY(-50%) translateX(20px);
    width: min(90%, 360px);
    padding: 1.4rem 1.25rem;
    border-radius: 1rem;
    background: rgba(19, 27, 40, 0.82);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(185, 210, 230, 0.26);
    color: #eaf0ff;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.45s ease, transform 0.45s ease;
    z-index: 2;
  }

  .lamp-scene.active .login-form-panel {
    opacity: 1;
    transform: translateY(-50%) translateX(0);
    pointer-events: auto;
  }

  .login-form-panel h3 {
    color: #ffffff;
  }

  .login-form-panel .form-label {
    color: rgba(236, 244, 255, 0.9);
  }

  .login-form-panel .form-control {
    border: 1px solid rgba(175, 199, 220, 0.3);
    background: rgba(214, 228, 243, 0.12);
    color: #ffffff;
  }

  .login-form-panel .form-control::placeholder {
    color: rgba(219, 232, 246, 0.62);
  }

  .login-form-panel .form-control:focus {
    border-color: #f1da84;
    box-shadow: 0 0 0 0.15rem rgba(241, 218, 132, 0.25);
    background: rgba(214, 228, 243, 0.2);
    color: #ffffff;
  }

  .login-submit-btn {
    width: 100%;
    border: none;
    border-radius: 999px;
    padding: 0.58rem 1rem;
    font-weight: 600;
    color: #3e2e03;
    background: linear-gradient(90deg, #ecd084 0%, #f6e7a8 45%, #d4b157 100%);
  }

  @media (max-width: 900px) {
    .lamp-scene {
      min-height: 640px;
    }

    .lamp-wrap {
      left: 50%;
      transform: translateX(-50%);
      top: 16%;
    }

    .lamp-glow {
      left: 50%;
      transform: translateX(-50%);
    }

    .pull-cord {
      left: calc(50% + 12px);
      top: 19%;
      transform: translateX(-50%) translateY(var(--pull-y));
    }

    .login-form-panel {
      left: 50%;
      right: auto;
      top: auto;
      bottom: 6%;
      transform: translateX(-50%) translateY(18px);
      width: min(92%, 390px);
    }

    .lamp-scene.active .login-form-panel {
      transform: translateX(-50%) translateY(0);
    }
  }
</style>

<section class="login-lamp-page">
  <div class="lamp-scene" id="lampScene" data-on="false">
    <p class="lamp-instruction">Pull the cord to show/hide the login</p>
    <div class="lamp-wrap" aria-hidden="true">
      <div class="lamp-glow"></div>
      <div class="lamp-shade"></div>
      <div class="lamp-stand"></div>
      <div class="lamp-base"></div>
    </div>

    <div class="pull-cord" id="pullCord">
      <button type="button" id="cordKnob" class="cord-knob" aria-label="Pull lamp cord to toggle login form"></button>
    </div>

    <div class="login-form-panel" id="loginFormPanel">
      <h3 class="mb-3">Welcome</h3>

      <% if (error) { %>
        <div class="alert alert-danger py-2 mb-3"><%= error %></div>
      <% } %>

      <form method="POST" action="/login">
        <div class="mb-2">
          <label for="username" class="form-label">Username</label>
          <input
            id="username"
            name="username"
            type="text"
            class="form-control"
            placeholder="Enter username"
            autocomplete="username"
            required
          />
        </div>

        <div class="mb-3">
          <label for="password" class="form-label">Password</label>
          <input
            id="password"
            name="password"
            type="password"
            class="form-control"
            placeholder="Enter password"
            autocomplete="current-password"
            required
          />
        </div>

        <button type="submit" class="login-submit-btn">Sign in</button>
      </form>

      <div class="text-center mt-3">
        <a href="/register" class="text-decoration-none text-light-emphasis">New user? Create account</a>
      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    var scene = document.getElementById("lampScene");
    var cord = document.getElementById("pullCord");
    var knob = document.getElementById("cordKnob");
    if (!scene || !cord || !knob) return;

    var dragging = false;
    var startY = 0;
    var currentPull = 0;
    var pullThreshold = 55;
    var pointerId = null;

    function applyPull(px) {
      currentPull = Math.max(0, Math.min(85, px));
      cord.style.setProperty("--pull-y", currentPull + "px");
    }

    function setActive(on) {
      scene.setAttribute("data-on", on ? "true" : "false");
      scene.classList.toggle("active", on);
    }

    function toggleScene() {
      var isOn = scene.getAttribute("data-on") === "true";
      setActive(!isOn);
    }

    function startPull(clientY) {
      dragging = true;
      startY = clientY;
    }

    function movePull(clientY) {
      if (!dragging) return;
      applyPull(clientY - startY);
    }

    function endPull() {
      if (!dragging) return;
      dragging = false;
      if (currentPull >= pullThreshold) toggleScene();
      applyPull(0);
      pointerId = null;
    }

    function getTouchY(e) {
      return e.touches && e.touches[0] ? e.touches[0].clientY : null;
    }

    cord.addEventListener("pointerdown", function (e) {
      pointerId = e.pointerId;
      startPull(e.clientY);
      if (cord.setPointerCapture) {
        try {
          cord.setPointerCapture(pointerId);
        } catch (err) {}
      }
      e.preventDefault();
    });

    cord.addEventListener("pointermove", function (e) {
      if (pointerId !== null && e.pointerId !== pointerId) return;
      movePull(e.clientY);
    });

    cord.addEventListener("pointerup", endPull);
    cord.addEventListener("pointercancel", endPull);

    cord.addEventListener("mousedown", function (e) {
      startPull(e.clientY);
      e.preventDefault();
    });
    window.addEventListener("mousemove", function (e) {
      movePull(e.clientY);
    });
    window.addEventListener("mouseup", endPull);

    cord.addEventListener(
      "touchstart",
      function (e) {
        var y = getTouchY(e);
        if (y === null) return;
        startPull(y);
        e.preventDefault();
      },
      { passive: false }
    );
    window.addEventListener(
      "touchmove",
      function (e) {
        var y = getTouchY(e);
        if (y === null) return;
        movePull(y);
      },
      { passive: false }
    );
    window.addEventListener("touchend", endPull);
    window.addEventListener("touchcancel", endPull);

    knob.addEventListener("click", function (e) {
      if (!dragging && currentPull < 5) toggleScene();
      e.preventDefault();
    });
  })();
</script>

