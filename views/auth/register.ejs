<% layout("/layouts/boilerplate") %>

<div class="row justify-content-center mt-5">
  <div class="col-12 col-md-9 col-lg-6">
    <div class="card shadow-sm border-0">
      <div class="card-body p-4">
        <h3 class="mb-1">Create account</h3>
        <p class="text-muted mb-4">Register a new User or Admin.</p>

        <% if (error) { %>
          <div class="alert alert-danger"><%= error %></div>
        <% } %>

        <form method="POST" action="/register">
          <div class="mb-3">
            <label for="username" class="form-label">Username</label>
            <input
              id="username"
              name="username"
              type="text"
              class="form-control"
              placeholder="e.g. keshav"
              autocomplete="username"
              required
            />
          </div>

          <div class="row">
            <div class="mb-3 col-md-6">
              <label for="password" class="form-label">Password</label>
              <input
                id="password"
                name="password"
                type="password"
                class="form-control"
                autocomplete="new-password"
                required
              />
            </div>
            <div class="mb-3 col-md-6">
              <label for="confirmPassword" class="form-label">Confirm password</label>
              <input
                id="confirmPassword"
                name="confirmPassword"
                type="password"
                class="form-control"
                autocomplete="new-password"
                required
              />
            </div>
          </div>

          <div class="mb-3">
            <label for="role" class="form-label">Account type</label>
            <select id="role" name="role" class="form-select" required>
              <option value="user" selected>User</option>
              <option value="admin">Admin</option>
            </select>
            <div class="form-text">
              Admin requires an admin secret (ask your admin).
            </div>
          </div>

          <div class="mb-2 form-check">
            <input class="form-check-input" type="checkbox" id="toggleAdminHelp" />
            <label class="form-check-label" for="toggleAdminHelp">
              What is “Admin secret”?
            </label>
          </div>
          <div id="adminHelp" class="alert alert-info py-2 d-none" role="alert">
            Admin secret is an extra code required only for creating Admin accounts.
            In this project the default is <code>staybee-admin</code> (can be changed using <code>ADMIN_SIGNUP_SECRET</code>).
          </div>

          <div class="mb-4 d-none" id="adminSecretWrap">
            <label for="adminSignupSecret" class="form-label">Admin secret (only for Admin)</label>
            <input
              id="adminSignupSecret"
              name="adminSignupSecret"
              type="password"
              class="form-control"
              placeholder="Enter admin secret if you selected Admin"
            />
          </div>

          <div class="d-grid">
            <button type="submit" class="btn btn-primary">Create account</button>
          </div>
        </form>

        <div class="text-center mt-3">
          <a href="/login" class="text-decoration-none">Back to login</a>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  (function () {
    const roleEl = document.getElementById("role");
    const adminWrap = document.getElementById("adminSecretWrap");
    const adminSecretInput = document.getElementById("adminSignupSecret");
    const helpToggle = document.getElementById("toggleAdminHelp");
    const helpBox = document.getElementById("adminHelp");

    function syncRoleUI() {
      const isAdmin = roleEl && roleEl.value === "admin";
      if (!adminWrap) return;
      adminWrap.classList.toggle("d-none", !isAdmin);
      if (!isAdmin && adminSecretInput) adminSecretInput.value = "";
    }

    function syncHelpUI() {
      if (!helpBox || !helpToggle) return;
      helpBox.classList.toggle("d-none", !helpToggle.checked);
    }

    if (roleEl) roleEl.addEventListener("change", syncRoleUI);
    if (helpToggle) helpToggle.addEventListener("change", syncHelpUI);
    syncRoleUI();
    syncHelpUI();
  })();
</script>

