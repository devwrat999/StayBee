<% layout("/layouts/boilerplate") %>

<style>
  body {
    background:
      radial-gradient(circle at 18% 22%, rgba(88, 119, 181, 0.2) 0%, rgba(88, 119, 181, 0) 40%),
      radial-gradient(circle at 82% 78%, rgba(72, 177, 166, 0.16) 0%, rgba(72, 177, 166, 0) 42%),
      linear-gradient(145deg, #070b13 0%, #0a1020 45%, #080c16 100%);
    color: #e6edf7;
  }

  .navbar,
  .f-info {
    display: none !important;
  }

  .register-lamp-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.25rem 0;
    opacity: 0;
    transform: translateX(0);
    transition: transform 0.28s ease, opacity 0.22s ease;
  }

  .register-lamp-page.page-enter-active {
    opacity: 1;
    transform: translateX(0);
  }

  .register-lamp-page.page-enter-from-right {
    transform: translateX(40px);
  }

  .register-lamp-page.page-enter-from-left {
    transform: translateX(-40px);
  }

  .register-lamp-page.page-exit-right {
    opacity: 0;
    transform: translateX(42px);
  }

  .lamp-scene {
    --scene-bg: #0a0f1a;
    --scene-bg-active: #111a26;
    width: 100%;
    max-width: 1040px;
    min-height: 620px;
    border-radius: 1.1rem;
    position: relative;
    overflow: hidden;
    background: radial-gradient(circle at 25% 35%, #111a27 0%, var(--scene-bg) 55%, #060a12 100%);
    transition: background 0.5s ease, box-shadow 0.5s ease;
    border: 1px solid rgba(162, 188, 226, 0.16);
    box-shadow: 0 20px 55px rgba(3, 7, 16, 0.6);
  }

  .lamp-scene.active {
    background: radial-gradient(circle at 28% 35%, rgba(255, 223, 130, 0.24) 0%, var(--scene-bg-active) 50%, #09101a 100%);
  }

  .lamp-instruction {
    position: absolute;
    top: 1.25rem;
    left: 50%;
    transform: translateX(-50%) translateY(0);
    margin: 0;
    color: rgba(226, 236, 250, 0.86);
    font-size: clamp(0.84rem, 1.15vw, 0.96rem);
    font-weight: 500;
    letter-spacing: 0.015em;
    line-height: 1.3;
    text-align: center;
    padding: 0.3rem 0.8rem;
    border-radius: 999px;
    background: rgba(20, 30, 45, 0.35);
    border: 1px solid rgba(171, 194, 222, 0.2);
    backdrop-filter: blur(6px);
    transition: opacity 0.35s ease, transform 0.35s ease;
    opacity: 1;
    z-index: 4;
    pointer-events: none;
  }

  .lamp-scene.active .lamp-instruction {
    opacity: 0;
    transform: translateX(-50%) translateY(-12px);
  }

  .lamp-wrap {
    position: absolute;
    left: 8%;
    top: 22%;
    width: 220px;
    height: 320px;
    pointer-events: none;
  }

  .lamp-shade {
    width: 150px;
    height: 72px;
    background: #f2f3ef;
    border-radius: 78px 78px 18px 18px;
    margin: 0 auto;
    box-shadow: 0 0 16px rgba(255, 255, 255, 0.2);
  }

  .lamp-stand {
    width: 12px;
    height: 148px;
    background: #edece7;
    margin: 0.5rem auto 0;
    border-radius: 8px;
  }

  .lamp-base {
    width: 94px;
    height: 11px;
    border-radius: 999px;
    background: #ecebe7;
    margin: 0.4rem auto 0;
  }

  .lamp-glow {
    position: absolute;
    top: -4%;
    left: -20%;
    width: 350px;
    height: 350px;
    background: radial-gradient(circle, rgba(255, 225, 130, 0.36) 0%, rgba(255, 225, 130, 0.12) 34%, rgba(255, 225, 130, 0) 72%);
    opacity: 0;
    transition: opacity 0.5s ease;
    pointer-events: none;
  }

  .lamp-scene.active .lamp-glow {
    opacity: 1;
  }

  .pull-cord {
    position: absolute;
    left: calc(8% + 124px);
    top: 23%;
    width: 24px;
    height: 130px;
    background: linear-gradient(
      to right,
      transparent calc(50% - 1px),
      rgba(220, 220, 220, 0.9) calc(50% - 1px),
      rgba(220, 220, 220, 0.9) calc(50% + 1px),
      transparent calc(50% + 1px)
    );
    --pull-y: 0px;
    transform: translateY(var(--pull-y));
    transition: transform 0.2s ease;
    z-index: 3;
    touch-action: none;
    cursor: grab;
  }

  .cord-knob {
    position: absolute;
    bottom: -9px;
    left: 50%;
    width: 18px;
    height: 18px;
    transform: translateX(-50%);
    border-radius: 50%;
    border: 0;
    background: radial-gradient(circle at 35% 35%, #fff2cf 0%, #c9b18b 70%);
    box-shadow: 0 0 4px rgba(255, 213, 132, 0.55);
    cursor: grab;
  }

  .register-form-panel {
    position: absolute;
    right: 8%;
    top: 50%;
    transform: translateY(-50%) translateX(20px);
    width: min(92%, 430px);
    padding: 1.4rem 1.25rem;
    border-radius: 1rem;
    background: rgba(19, 27, 40, 0.82);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(185, 210, 230, 0.26);
    color: #eaf0ff;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.45s ease, transform 0.45s ease;
    z-index: 2;
  }

  .lamp-scene.active .register-form-panel {
    opacity: 1;
    transform: translateY(-50%) translateX(0);
    pointer-events: auto;
  }

  .register-form-panel h3 {
    color: #ffffff;
    margin-bottom: 0.2rem;
  }

  .register-subtitle {
    color: rgba(221, 231, 244, 0.76);
    font-size: 0.88rem;
    margin-bottom: 0.9rem;
  }

  .register-form-panel .form-label,
  .register-form-panel .form-check-label {
    color: rgba(236, 244, 255, 0.9);
  }

  .register-form-panel .form-control,
  .register-form-panel .form-select {
    border: 1px solid rgba(175, 199, 220, 0.3);
    background: rgba(214, 228, 243, 0.12);
    color: #ffffff;
  }

  .register-form-panel .form-select {
    background-color: rgba(214, 228, 243, 0.14);
    border-color: rgba(175, 199, 220, 0.35);
  }

  .register-form-panel .form-control::placeholder {
    color: rgba(219, 232, 246, 0.62);
  }

  .register-form-panel .form-control:focus,
  .register-form-panel .form-select:focus {
    border-color: #f1da84;
    box-shadow: 0 0 0 0.15rem rgba(241, 218, 132, 0.25);
    background: rgba(214, 228, 243, 0.2);
    color: #ffffff;
  }

  .register-form-panel .form-select option {
    background-color: #1a2433;
    color: #e9f2ff;
  }

  .register-form-panel .form-select option:hover {
    background-color: #24364b;
    color: #ffffff;
  }

  .register-form-panel .form-select option:checked {
    background-color: #4f7c82;
    color: #ffffff;
  }

  .register-form-panel .form-text {
    color: rgba(206, 220, 236, 0.72);
  }

  .register-form-panel .alert-info {
    background: rgba(13, 202, 240, 0.14);
    border-color: rgba(13, 202, 240, 0.3);
    color: #d7f6ff;
  }

  .register-submit-btn {
    width: 100%;
    border: none;
    border-radius: 999px;
    padding: 0.58rem 1rem;
    font-weight: 600;
    color: #3e2e03;
    background: linear-gradient(90deg, #ecd084 0%, #f6e7a8 45%, #d4b157 100%);
  }

  .register-back-link {
    color: rgba(236, 244, 255, 0.86) !important;
  }

  @media (max-width: 900px) {
    .lamp-scene {
      min-height: 740px;
    }

    .lamp-wrap {
      left: 50%;
      transform: translateX(-50%);
      top: 16%;
    }

    .lamp-glow {
      left: 50%;
      transform: translateX(-50%);
    }

    .pull-cord {
      left: calc(50% + 12px);
      top: 19%;
      transform: translateX(-50%) translateY(var(--pull-y));
    }

    .register-form-panel {
      left: 50%;
      right: auto;
      top: auto;
      bottom: 5%;
      transform: translateX(-50%) translateY(18px);
      width: min(93%, 430px);
    }

    .lamp-scene.active .register-form-panel {
      transform: translateX(-50%) translateY(0);
    }
  }
</style>

<section class="register-lamp-page" id="authPageContainer">
  <div class="lamp-scene" id="lampScene" data-on="false">
    <p class="lamp-instruction">Pull the cord to show/hide the registration form</p>
    <div class="lamp-wrap" aria-hidden="true">
      <div class="lamp-glow"></div>
      <div class="lamp-shade"></div>
      <div class="lamp-stand"></div>
      <div class="lamp-base"></div>
    </div>

    <div class="pull-cord" id="pullCord">
      <button type="button" id="cordKnob" class="cord-knob" aria-label="Pull lamp cord to toggle registration form"></button>
    </div>

    <div class="register-form-panel" id="registerFormPanel">
      <h3>Create account</h3>
      <p class="register-subtitle">Register a new User or Admin.</p>

      <% if (error) { %>
        <div class="alert alert-danger py-2 mb-3"><%= error %></div>
      <% } %>

      <form method="POST" action="/register" id="registerForm">
        <div class="mb-2">
          <label for="username" class="form-label">Username</label>
          <input
            id="username"
            name="username"
            type="text"
            class="form-control"
            placeholder="Enter username"
            autocomplete="username"
            required
          />
        </div>

        <div class="row">
          <div class="mb-2 col-md-6">
            <label for="password" class="form-label">Password</label>
            <input
              id="password"
              name="password"
              type="password"
              class="form-control"
              placeholder="Enter password"
              autocomplete="new-password"
              required
            />
          </div>
          <div class="mb-2 col-md-6">
            <label for="confirmPassword" class="form-label">Confirm Password</label>
            <input
              id="confirmPassword"
              name="confirmPassword"
              type="password"
              class="form-control"
              placeholder="Confirm password"
              autocomplete="new-password"
              required
            />
          </div>
        </div>

        <div class="mb-2">
          <label for="role" class="form-label">Account Type</label>
          <select id="role" name="role" class="form-select" required>
            <option value="user" selected>User</option>
            <option value="admin">Admin</option>
          </select>
          <div class="form-text">Admin requires an admin secret (ask your admin).</div>
        </div>

        <div class="mb-2 form-check">
          <input class="form-check-input" type="checkbox" id="toggleAdminHelp" />
          <label class="form-check-label" for="toggleAdminHelp">What is Admin secret?</label>
        </div>
        <div id="adminHelp" class="alert alert-info py-2 d-none" role="alert">
          Admin secret is an extra code required only for creating Admin accounts.
          In this project the default is <code>staybee-admin</code> (can be changed using <code>ADMIN_SIGNUP_SECRET</code>).
        </div>

        <div class="mb-3 d-none" id="adminSecretWrap">
          <label for="adminSignupSecret" class="form-label">Admin secret (only for Admin)</label>
          <input
            id="adminSignupSecret"
            name="adminSignupSecret"
            type="password"
            class="form-control"
            placeholder="Enter admin secret if you selected Admin"
          />
        </div>

        <button type="submit" class="register-submit-btn">Create Account</button>
      </form>

      <div class="text-center mt-3">
        <a href="/login" id="backToLoginLink" class="text-decoration-none register-back-link">Back to Login</a>
      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    var scene = document.getElementById("lampScene");
    var cord = document.getElementById("pullCord");
    var knob = document.getElementById("cordKnob");
    var LAMP_SESSION_KEY = "staybeeLampSessionOn";
    var TRANSITION_KEY = "staybeeAuthPageTransition";
    var pageContainer = document.getElementById("authPageContainer");
    var registerForm = document.getElementById("registerForm");
    var backToLoginLink = document.getElementById("backToLoginLink");

    var roleEl = document.getElementById("role");
    var adminWrap = document.getElementById("adminSecretWrap");
    var adminSecretInput = document.getElementById("adminSignupSecret");
    var helpToggle = document.getElementById("toggleAdminHelp");
    var helpBox = document.getElementById("adminHelp");

    if (!scene || !cord || !knob) return;

    var dragging = false;
    var startY = 0;
    var currentPull = 0;
    var pullThreshold = 55;
    var pointerId = null;

    function applyPull(px) {
      currentPull = Math.max(0, Math.min(85, px));
      cord.style.setProperty("--pull-y", currentPull + "px");
    }

    function setActive(on) {
      scene.setAttribute("data-on", on ? "true" : "false");
      scene.classList.toggle("active", on);
      try {
        sessionStorage.setItem(LAMP_SESSION_KEY, on ? "true" : "false");
      } catch (err) {}
    }

    function toggleScene() {
      var isOn = scene.getAttribute("data-on") === "true";
      setActive(!isOn);
    }

    try {
      var navEntry =
        window.performance &&
        typeof window.performance.getEntriesByType === "function" &&
        window.performance.getEntriesByType("navigation")[0];
      var isReload =
        (navEntry && navEntry.type === "reload") ||
        (window.performance && window.performance.navigation && window.performance.navigation.type === 1);
      if (isReload) {
        sessionStorage.removeItem(LAMP_SESSION_KEY);
      }
      var savedLampState = sessionStorage.getItem(LAMP_SESSION_KEY) === "true";
      setActive(savedLampState);
    } catch (err) {
      setActive(false);
    }

    if (pageContainer) {
      var transitionDir = null;
      try {
        transitionDir = sessionStorage.getItem(TRANSITION_KEY);
        sessionStorage.removeItem(TRANSITION_KEY);
      } catch (err) {}

      if (transitionDir === "forward") {
        pageContainer.classList.add("page-enter-from-right");
      } else if (transitionDir === "back") {
        pageContainer.classList.add("page-enter-from-left");
      }

      requestAnimationFrame(function () {
        pageContainer.classList.add("page-enter-active");
      });
    }

    if (backToLoginLink && pageContainer) {
      backToLoginLink.addEventListener("click", function (e) {
        e.preventDefault();
        try {
          sessionStorage.setItem(TRANSITION_KEY, "back");
        } catch (err) {}
        pageContainer.classList.add("page-exit-right");
        setTimeout(function () {
          window.location.href = backToLoginLink.href;
        }, 220);
      });
    }

    if (registerForm && pageContainer) {
      var submitting = false;
      registerForm.addEventListener("submit", function (e) {
        if (submitting) return;
        e.preventDefault();
        submitting = true;
        try {
          sessionStorage.setItem(TRANSITION_KEY, "back");
        } catch (err) {}
        pageContainer.classList.add("page-exit-right");
        setTimeout(function () {
          registerForm.submit();
        }, 180);
      });
    }

    function startPull(clientY) {
      dragging = true;
      startY = clientY;
    }

    function movePull(clientY) {
      if (!dragging) return;
      applyPull(clientY - startY);
    }

    function endPull() {
      if (!dragging) return;
      dragging = false;
      if (currentPull >= pullThreshold) toggleScene();
      applyPull(0);
      pointerId = null;
    }

    function getTouchY(e) {
      return e.touches && e.touches[0] ? e.touches[0].clientY : null;
    }

    cord.addEventListener("pointerdown", function (e) {
      pointerId = e.pointerId;
      startPull(e.clientY);
      if (cord.setPointerCapture) {
        try {
          cord.setPointerCapture(pointerId);
        } catch (err) {}
      }
      e.preventDefault();
    });

    cord.addEventListener("pointermove", function (e) {
      if (pointerId !== null && e.pointerId !== pointerId) return;
      movePull(e.clientY);
    });

    cord.addEventListener("pointerup", endPull);
    cord.addEventListener("pointercancel", endPull);

    cord.addEventListener("mousedown", function (e) {
      startPull(e.clientY);
      e.preventDefault();
    });
    window.addEventListener("mousemove", function (e) {
      movePull(e.clientY);
    });
    window.addEventListener("mouseup", endPull);

    cord.addEventListener(
      "touchstart",
      function (e) {
        var y = getTouchY(e);
        if (y === null) return;
        startPull(y);
        e.preventDefault();
      },
      { passive: false }
    );
    window.addEventListener(
      "touchmove",
      function (e) {
        var y = getTouchY(e);
        if (y === null) return;
        movePull(y);
      },
      { passive: false }
    );
    window.addEventListener("touchend", endPull);
    window.addEventListener("touchcancel", endPull);

    knob.addEventListener("click", function (e) {
      if (!dragging && currentPull < 5) toggleScene();
      e.preventDefault();
    });

    function syncRoleUI() {
      var isAdmin = roleEl && roleEl.value === "admin";
      if (!adminWrap) return;
      adminWrap.classList.toggle("d-none", !isAdmin);
      if (!isAdmin && adminSecretInput) adminSecretInput.value = "";
    }

    function syncHelpUI() {
      if (!helpBox || !helpToggle) return;
      helpBox.classList.toggle("d-none", !helpToggle.checked);
    }

    if (roleEl) roleEl.addEventListener("change", syncRoleUI);
    if (helpToggle) helpToggle.addEventListener("change", syncHelpUI);
    syncRoleUI();
    syncHelpUI();
  })();
</script>

